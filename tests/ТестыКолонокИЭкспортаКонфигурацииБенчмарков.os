&Тест
Процедура ТестДолжен_НастроитьПредставлениеПользовательскойКолонкиЧерезАдаптер() Экспорт

	// Подготовка
	РезультатЗапускаКейса = ТестовыйРезультатЗапускаКейса("10, 20, 30");

	Колонка = КолонкиОтчетаБенчмарков.СоздатьПользовательскую("Пользовательская");
	
	ПараметрыПредставления = Новый ПараметрыПредставленияКолонкиОтчетаБенчмарков();
	ПараметрыПредставления.ФорматнаяСтрока = "fmt";

	// Действие
	Представление = Колонка.ПредставлениеЗначения("custom", РезультатЗапускаКейса, ПараметрыПредставления);

	// Проверка
	Ожидаем.Что(Колонка.ДелегатПредставлениеЗначения).Не_().ЭтоНеопределено();
	Ожидаем.Что(Представление).Равно("custom|20|fmt");

