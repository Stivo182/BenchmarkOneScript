#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ТестовыйРезультатЗапускаКейса(СтрокаЗамеровВремени, СтрокаЗамеровПамяти = "")

	Замеры = Новый Структура(
		"ЗамерыВремени, ЗамерыПамяти",
		МассивЧисел(СтрокаЗамеровВремени),
		МассивЧисел(СтрокаЗамеровПамяти)
	);

	РезультатЗапускаКейса = Новый РезультатЗапускаКейса();
	РезультатЗапускаКейса.Статистика = Новый СтатистикаБенчмарка(Замеры);

	Возврат РезультатЗапускаКейса;

КонецФункции

Функция МассивЧисел(СтрокаЗначений)

	Результат = Новый Массив();

	Для Каждого Значение Из СтрРазделить(СтрокаЗначений, ", ", Ложь) Цикл
		Результат.Добавить(Число(Значение));
	КонецЦикла;

	Возврат Результат;

КонецФункции

#КонецОбласти
