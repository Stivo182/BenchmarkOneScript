&Тест
&Параметры(0, "0 B")
&Параметры(1, "1 B")
&Параметры(512, "512 B")
&Параметры(1024, "1 KB")
&Параметры(524288, "512 KB")
&Параметры(1048576, "1 MB")
&Параметры(536870912, "512 MB")
&Параметры(1073741824, "1 GB")
&Параметры(1099511627776, "1,024 GB")
Процедура ТестДолжен_ФорматироватьБайтыВЧитаемыйВид(Значение, ОжидаемоеПредставление) Экспорт

	// Действие
	Результат = ПредставленияПоказателейБенчмарков.ПредставлениеЧитаемое(
		Значение,
		ЕдиницыИзмеренийБенчмарков.Байт
	);

	// Проверка
	Ожидаем.Что(Результат).Равно(ОжидаемоеПредставление);

КонецПроцедуры

