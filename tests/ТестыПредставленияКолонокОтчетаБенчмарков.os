&Тест
Процедура ТестДолжен_УдалитьКолонкуИзОтчетаПоИмени() Экспорт

	// Подготовка
	Отчет = Новый ОтчетБенчмарков();
	Отчет.ДобавитьКолонку("Среднее");

	// Действие
	Отчет.УдалитьКолонку("Среднее");

	// Проверка
	Ожидаем.Что(Отчет.Колонки()).ИмеетДлину(0);
	Ожидаем.Что(Отчет.Таблица().Колонки.Найти("Среднее")).ЭтоНеопределено();

