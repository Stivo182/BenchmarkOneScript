Функция ПолучитьЧисловыеЗначения() Экспорт

	Значения = Новый Массив();
	Значения.Добавить(300);
	Значения.Добавить(400);

	Возврат Значения;

КонецФункции

Функция ПолучитьСсылочныеЗначения() Экспорт

	Значения = Новый Массив();
	Значения.Добавить(Новый Структура("ИмяКлюча", "Значение 1"));
	Значения.Добавить(Новый Структура("ИмяКлюча", "Значение 2"));
	Значения.Добавить(Новый HTTPЗапрос());

	Возврат Значения;

КонецФункции