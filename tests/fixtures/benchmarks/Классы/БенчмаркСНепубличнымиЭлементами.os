Функция ОткрытыйИсточник() Экспорт

	Значения = Новый Массив();
	Значения.Добавить(1);

	Возврат Значения;

КонецФункции

Функция ЗакрытыйИсточник()

	Значения = Новый Массив();
	Значения.Добавить(1);

	Возврат Значения;

КонецФункции

