&Тест
Процедура ТестДолжен_ЗапуститьОдинБенчмаркОднойИтерациейБезПараметровБезПамяти() Экспорт
	
	// Подготовка
	Тип = Тип("ПустойБенчмарк");

	Конфигурация = Новый КонфигурацияБенчмарков(Тип)
		.УстановитьСтратегию(СтратегииЗапускаБенчмарка.ХолодныйЗапуск)
		.УстановитьКоличествоИтераций(1)
		.УдалитьМониторингПамяти();

	// Действие
	Результат = Бенчмаркинг.Запустить(Тип, Конфигурация);

	// Проверка
	Ожидаем.Что(Результат.Запуски, "Запуски").ИмеетДлину(1);
	Ожидаем.Что(Результат.Запуски[0].Замеры, "Замеры").ИмеетДлину(1);

	ПроверитьЗамеры(Результат.Запуски[0].Замеры, 1, 1, ЭтапыБенчмарка.Измерение);

КонецПроцедуры

