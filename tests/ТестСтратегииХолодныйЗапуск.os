	ПроверитьЗамеры(Результат.Запуски[0].Замеры, 1, 1, ЭтапыБенчмарка.Измерение);
	ПроверитьЗамеры(Результат.Запуски[0].Замеры, 2, 2, ЭтапыБенчмарка.Память);

КонецПроцедуры

