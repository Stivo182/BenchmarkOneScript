#Использовать tempfiles
#Использовать logos

Перем _МенеджерВременныхФайлов; // МенеджерВременныхФайлов
Перем _Лог; // Лог

#Область ОбработчикиСобытий

// Создает подготовитель файлов бенчмарка.
//
// Параметры:
//   МенеджерВременныхФайлов - МенеджерВременныхФайлов, Неопределено -
//       Внешний менеджер временных файлов. Если не передан, создается новый.
Процедура ПриСозданииОбъекта(МенеджерВременныхФайлов = Неопределено)

	Если МенеджерВременныхФайлов = Неопределено Тогда
		_МенеджерВременныхФайлов = Новый МенеджерВременныхФайлов();
	Иначе
		_МенеджерВременныхФайлов = МенеджерВременныхФайлов;
	КонецЕсли;

	_Лог = Логирование.ПолучитьЛог("oscript.lib.benchmark.ПодготовительФайлаБенчмарка");

КонецПроцедуры

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Подготавливает файл для запуска через стандартный пайплайн бенчмарков.
//
// Если файл уже содержит хотя бы один бенчмарк, возвращается исходный путь.
// Если бенчмарков нет, создается временный файл, в котором код модуля
// оборачивается в процедуру с аннотацией &Бенчмарк.
//
// Параметры:
//   ПутьКФайлу - Строка - Путь к исходному файлу сценария
//
// Возвращаемое значение:
//   Строка - Путь к исходному или временному файлу
Функция Подготовить(ПутьКФайлу) Экспорт

	СодержимоеФайла = ПрочитатьФайл(ПутьКФайлу);
	Если ЕстьАннотацияБенчмарка(СодержимоеФайла) Тогда
		Возврат ПутьКФайлу;
	КонецЕсли;

	ИмяФайла = Новый Файл(ПутьКФайлу).ИмяБезРасширения;
	ПутьКВременномуФайлу = _МенеджерВременныхФайлов.НовоеИмяФайла("os");
	ЗаписатьФайл(ПутьКВременномуФайлу, ТекстВременногоБенчмарка(СодержимоеФайла, ИмяФайла));

	_Лог.Отладка("Создан временный файл <%1> для запуска алгоритма из <%2>", ПутьКВременномуФайлу, ПутьКФайлу);

	Возврат ПутьКВременномуФайлу;

КонецФункции

// Удаляет все временные файлы, созданные в процессе подготовки.
//
// Метод следует вызывать после завершения запуска или при ошибке, чтобы
// освободить накопленные временные ресурсы.
Процедура Очистить() Экспорт

	_МенеджерВременныхФайлов.Удалить();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПрочитатьФайл(ПутьКФайлу)

	ЧтениеТекста = Новый ЧтениеТекста(ПутьКФайлу);
	СодержимоеФайла = ЧтениеТекста.Прочитать();
	ЧтениеТекста.Закрыть();

	Возврат СодержимоеФайла;

КонецФункции

Процедура ЗаписатьФайл(ПутьКФайлу, СодержимоеФайла)

	ЗаписьТекста = Новый ЗаписьТекста(ПутьКФайлу);
	ЗаписьТекста.Записать(СодержимоеФайла);
	ЗаписьТекста.Закрыть();

КонецПроцедуры

Функция ЕстьАннотацияБенчмарка(СодержимоеФайла)

	Для Каждого СтрокаФайла Из СтрРазделить(СодержимоеФайла, Символы.ПС, Ложь) Цикл
		Если СтрНачинаетсяС(НРег(СокрЛП(СтрокаФайла)), "&бенчмарк") Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;

	Возврат Ложь;

КонецФункции

Функция ТекстВременногоБенчмарка(СодержимоеФайла, ИмяФайла)

	Преамбула = Новый Массив();
	ТелоАлгоритма = Новый Массив();
	ТелоМодуляНачалось = Ложь;

	Для Каждого СтрокаФайла Из СтрРазделить(СодержимоеФайла, Символы.ПС, Ложь) Цикл

		СтрокаБезОтступов = СокрЛП(СтрокаФайла);

		Если Не ТелоМодуляНачалось И ЭтоСтрокаПреамбулы(СтрокаБезОтступов) Тогда
			Преамбула.Добавить(СтрокаФайла);
			Продолжить;
		КонецЕсли;

		ТелоМодуляНачалось = Истина;
		ТелоАлгоритма.Добавить(СтрокаФайла);

	КонецЦикла;

	ЧастиФайла = Новый Массив();
	Для Каждого СтрокаПреамбулы Из Преамбула Цикл
		ЧастиФайла.Добавить(СтрокаПреамбулы);
	КонецЦикла;

	Если Преамбула.Количество() > 0 Тогда
		ЧастиФайла.Добавить("");
	КонецЕсли;

	ЧастиФайла.Добавить(СтрШаблон("&Бенчмарк(Наименование = ""%1"")", ИмяФайла));
	ЧастиФайла.Добавить("Процедура Бенчмарк() Экспорт");

	Для Каждого СтрокаАлгоритма Из ТелоАлгоритма Цикл
		ЧастиФайла.Добавить(СтрокаАлгоритма);
	КонецЦикла;

	ЧастиФайла.Добавить("КонецПроцедуры");

	Возврат СтрСоединить(ЧастиФайла, Символы.ПС);

КонецФункции

Функция ЭтоСтрокаПреамбулы(СтрокаБезОтступов)

	Если Не ЗначениеЗаполнено(СтрокаБезОтступов) Тогда
		Возврат Истина;
	КонецЕсли;

	Если СтрНачинаетсяС(СтрокаБезОтступов, "#Использовать") Тогда
		Возврат Истина;
	КонецЕсли;

	Если СтрНачинаетсяС(СтрокаБезОтступов, "//") Тогда
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;

КонецФункции

#КонецОбласти
