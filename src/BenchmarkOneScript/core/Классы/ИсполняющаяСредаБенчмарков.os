// BSLLS:ExportVariables-off

&Сериализуемое("Version")
&Тип("Строка")
Перем Версия Экспорт; // Строка

&Сериализуемое("Name")
&Тип("Строка")
Перем Наименование Экспорт; // Строка

&Сериализуемое("Baseline")
&Тип("Булево")
Перем ЭтоЭталон Экспорт; // Булево

Процедура ПриСозданииОбъекта()
	
	Версия       = "";
	Наименование = "";
	ЭтоЭталон    = Ложь;

КонецПроцедуры